            required
            placeholder="Lim inn teksten her...

Bruk [[LYD]] der du vil starte ny lydfil."
        ></textarea>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary btn-large">
            Generer tekst
        </button>
    </div>

</form>

</section>

</main>

