<?php
declare(strict_types=1);

require_once __DIR__ . '/../../hn_core/inc/bootstrap.php';

use HnCore\Database\DatabaseManager;

$pdo = DatabaseManager::get('lex');

/* ==========================================================
   FILTER
========================================================== */

$allowed = ['pending','approved','rejected'];
$filter = $_GET['filter'] ?? 'pending';

if (!in_array($filter, $allowed, true)) {
    $filter = 'pending';
}

/* ==========================================================
   FETCH
========================================================== */

$stmt = $pdo->prepare("
    SELECT id, lemma, word_class, payload_json, status, created_at
    FROM lex_entries_staging
    WHERE status = ?
    ORDER BY created_at DESC
    LIMIT 50
");
$stmt->execute([$filter]);

$rows = $stmt->fetchAll(PDO::FETCH_ASSOC);

function h($v) {
    return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8');
}

/* ==========================================================
   FIELD STRUCTURE (KRITISK)
========================================================== */

$orderMap = [
    'verb' => [
        'infinitive',
        'present',
        'past',
        'past_participle',
        'present_participle',
        'imperative'
    ],
    'substantiv' => [
        'gender',
        'alt_gender',
        'indef_singular',
        'alt_indef_singular',
        'def_singular',
        'alt_def_singular',
        'indef_plural',
        'alt_indef_plural',
        'def_plural',
        'alt_def_plural'
    ],
    'adjektiv' => [
        'positive',
        'comparative',
        'superlative'
    ]
];
?>

<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<title>Godkjenning – Ordbok</title>

<style>
body { font-family: Arial; background:#f5f5f5; padding:20px; }

.topnav a {
    margin-right:10px;
    text-decoration:none;
    font-weight:bold;
    color:#3C6464;
}

.card {
    background:white;
    border-radius:8px;
    padding:15px;
    margin-bottom:20px;
}

.label { font-weight:bold; margin-top:10px; }

input[type=text], textarea {
    width:100%;
    margin-top:5px;
    padding:6px;
}

textarea { min-height:60px; }

.status {
    font-size:12px;
    margin-left:10px;
}

.badge {
    padding:4px 8px;
    border-radius:12px;
    font-size:12px;
    font-weight:bold;
}

.pending { background:#fff3cd; color:#8a6d3b; }
.approved { background:#d4edda; color:#155724; }
.rejected { background:#f8d7da; color:#721c24; }

.batch-bar {
    background:white;
    padding:10px;
    border-radius:8px;
    margin-bottom:15px;
}

button {
    padding:8px 12px;
    cursor:pointer;
}

.grammar-grid {
    margin-top:10px;
}

.grammar-header,
.grammar-row {
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap:6px;
}

.col-header {
    font-size:12px;
    font-weight:bold;
    color:#555;
}
</style>
</head>

<body>

<h1>Godkjenning av ordbok</h1>

<div class="topnav">
    <a href="?filter=pending">⏳ Pending</a>
    <a href="?filter=approved">✅ Godkjente</a>
    <a href="?filter=rejected">❌ Avviste</a>
</div>

<form method="post" action="batch_approve.php">

<div class="batch-bar">
    <label>
        <input type="checkbox" onclick="toggleAll(this)">
        Velg alle
    </label>

    <button name="action" value="approve">✔ Godkjenn valgte</button>
    <button name="action" value="reject">❌ Avvis valgte</button>
</div>

<?php foreach ($rows as $row):

    $data = json_decode($row['payload_json'], true);
    $grammar = $data['grammar'] ?? [];
    $keys = $orderMap[$row['word_class']] ?? array_keys($grammar);
?>

<div class="card" data-id="<?= $row['id'] ?>">

    <label>
        <input type="checkbox" name="ids[]" value="<?= $row['id'] ?>">
        Velg
    </label>

    <h3>
        <?= h($row['lemma']) ?> (<?= h($row['word_class']) ?>)
        <span class="badge <?= h($row['status']) ?>">
            <?= h($row['status']) ?>
        </span>
        <span class="status">Lagret</span>
    </h3>

    <div class="label">Bøyning</div>

    <div class="grammar-grid">

        <div class="grammar-header">
            <?php foreach ($keys as $k): ?>
                <div class="col-header"><?= h($k) ?></div>
            <?php endforeach; ?>
        </div>

        <div class="grammar-row">
            <?php foreach ($keys as $k): ?>
                <input type="text"
                       class="field"
                       data-type="grammar"
                       data-key="<?= h($k) ?>"
                       value="<?= h($grammar[$k] ?? '') ?>">
            <?php endforeach; ?>
        </div>

    </div>

    <div class="label">Forklaringer</div>

    <?php foreach (($data['senses'] ?? []) as $i => $sense): ?>

        <textarea class="field"
            data-type="definition"
            data-index="<?= $i ?>"><?= h($sense['definition'] ?? '') ?></textarea>

        <textarea class="field"
            data-type="example1"
            data-index="<?= $i ?>"><?= h($sense['example1'] ?? '') ?></textarea>

        <textarea class="field"
            data-type="example2"
            data-index="<?= $i ?>"><?= h($sense['example2'] ?? '') ?></textarea>

    <?php endforeach; ?>

    <div style="margin-top:10px;">
        <button type="button" onclick="approveSingle(<?= $row['id'] ?>)">OK</button>
        <button type="button" onclick="rejectSingle(<?= $row['id'] ?>)">Avvis</button>
    </div>

</div>

<?php endforeach; ?>

</form>

<script>
function approveSingle(id){ sendAction(id,'approve'); }
function rejectSingle(id){ sendAction(id,'reject'); }

function sendAction(id, action){
    const fd = new FormData();
    fd.append('id', id);
    fd.append('action', action);

    fetch('approve.php', { method:'POST', body:fd })
    .then(() => location.reload());
}

function toggleAll(source){
    document.querySelectorAll('input[name="ids[]"]').forEach(cb => {
        cb.checked = source.checked;
    });
}
</script>

</body>
</html>