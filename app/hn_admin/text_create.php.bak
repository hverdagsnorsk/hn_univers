        Velg bok → skriv tittel → lim inn tekst → generer.
    </p>
</header>

<section class="admin-card-section admin-text-create">

<?php if ($error !== ''): ?>
    <div class="alert-error"><?= h($error) ?></div>
<?php endif; ?>

<?php if ($success !== ''): ?>
    <div class="alert-success"><?= h($success) ?></div>
<?php endif; ?>

<form method="post" class="text-create-form" novalidate>

    <!-- 1. BOK -->

    <div class="form-block">
        <h3>1. Bok</h3>

        <label for="book_key_select">Velg eksisterende bok</label>
        <select id="book_key_select" name="book_key_select">
            <option value="">Velg eksisterende bok …</option>
            <?php foreach ($books as $bk): ?>
                <option value="<?= h((string)$bk) ?>">
                    <?= h((string)$bk) ?>
                </option>
            <?php endforeach; ?>
        </select>

        <div class="divider">eller</div>

        <label for="book_key_new">Opprett ny bok</label>
        <input
            id="book_key_new"
            name="book_key_new"
            placeholder="f.eks. consolvo2"
        >
    </div>

    <!-- 2. METADATA -->

    <div class="form-block horizontal">

        <div>
            <label for="level">Nivå (valgfritt)</label>
            <input
                id="level"
                name="level"
                placeholder="A2 / B1 / B2"
            >
        </div>

        <div>
            <label for="title">Tittel</label>
            <input
                id="title"
                name="title"
                required
            >
        </div>

    </div>

    <!-- 3. TEKST -->

    <div class="form-block">
        <h3>2. Tekstinnhold</h3>

        <label for="raw_text" class="visually-hidden">Tekstinnhold</label>

        <textarea
            id="raw_text"
