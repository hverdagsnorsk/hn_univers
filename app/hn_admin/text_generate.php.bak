<?php
declare(strict_types=1);

/*
|----------------------------------------------------------
| text_generate.php – 2026 CLEAN
|----------------------------------------------------------
| Ansvar:
|  - Leser ren tekst + [[LYD]]
|  - Genererer KUN innhold (figure/audio + p)
|  - Ingen layout, ingen header, ingen tools
|----------------------------------------------------------
*/

function generate_text_html(
    string $bookKey,
    string $textKey,
    string $title,
    string $rawText,
    ?string $level = null
): string {

    /* -----------------------------
       Normalisering
    ----------------------------- */
    $bookKeyLower = strtolower(trim($bookKey));

    if (!preg_match('/-(\d{3})$/', $textKey, $m)) {
        throw new RuntimeException('Ugyldig text_key.');
    }
    $textNumber = (int)$m[1];

    $cleanTitle = trim($title);
    if ($cleanTitle === '') {
        throw new RuntimeException('Tittel kan ikke være tom.');
    }

    $displayTitle = "Tekst {$textNumber}: {$cleanTitle}";
    $pageTitle    = $displayTitle . " | Hverdagsnorsk";

    /* -----------------------------
       Filstruktur
    ----------------------------- */
    $baseDir = $_SERVER['DOCUMENT_ROOT'] . "/hn_books/books/{$bookKeyLower}/texts";
    if (!is_dir($baseDir)) {
        if (!mkdir($baseDir, 0775, true) && !is_dir($baseDir)) {
            throw new RuntimeException('Kunne ikke opprette tekstmappe.');
        }
    }

    $fileName   = $textKey . '.html';
    $fullPath   = $baseDir . '/' . $fileName;
    $sourcePath = "/hn_books/books/{$bookKeyLower}/texts/{$fileName}";

    /* -----------------------------
       Segmentering ([[LYD]])
    ----------------------------- */
    $rawText = trim($rawText);
    if ($rawText === '') {
        throw new RuntimeException('Ingen tekstinnhold funnet.');
    }

    if (stripos($rawText, '[[LYD]]') !== false) {
        $blocks = preg_split('/\[\[\s*LYD\s*\]\]/i', $rawText);
    } else {
        $blocks = preg_split("/\R{2,}/", $rawText);
    }

    $blocks = array_values(array_filter(array_map('trim', $blocks)));
    if (!$blocks) {
        throw new RuntimeException('Ingen tekstblokker funnet.');
    }

    /* -----------------------------
       Audio-prefix
    ----------------------------- */
    $audioPrefix = strtoupper(substr($bookKeyLower, 0, 3));

    /* -----------------------------
       BYGG contentHtml (KUN INNHOLD)
    ----------------------------- */
    ob_start();

    foreach ($blocks as $i => $block):
        $audioIndex = $i + 1;
        $audioFile  = "../audio/{$audioPrefix}-{$textNumber}-{$audioIndex}.m4a";

        $paras = preg_split("/\R{2,}/", $block);
        $paras = array_values(array_filter(array_map('trim', $paras)));
    ?>
        <figure class="section-controls">
          <audio controls preload="metadata">
            <source src="<?= htmlspecialchars($audioFile, ENT_QUOTES, 'UTF-8') ?>" type="audio/mp4">
          </audio>
        </figure>

        <?php foreach ($paras as $para): ?>
          <p><?= nl2br(htmlspecialchars($para, ENT_QUOTES, 'UTF-8')) ?></p>
        <?php endforeach; ?>

    <?php endforeach;

    $contentHtml = ob_get_clean();

    /* -----------------------------
       Render via NY template
    ----------------------------- */
$templatePath = realpath(__DIR__ . '/templates/text_template.php');
if (!$templatePath) {
    throw new RuntimeException('Fant ikke text_template.php');
}
    $assetVersion = '2026-locked';

    ob_start();
    require $templatePath;
    $html = ob_get_clean();

    if (!$html) {
        throw new RuntimeException('Template rendret tom HTML.');
    }

    if (file_put_contents($fullPath, $html) === false) {
        throw new RuntimeException('Kunne ikke skrive HTML-fil.');
    }

    @chmod($fullPath, 0664);

    return $sourcePath;
}
