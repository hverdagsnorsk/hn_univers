/* ============================================================
   HN_BOOKS – READER 2026 (REFINED PEDAGOGICAL VERSION)
   ============================================================ */

:root {
  --font-scale: 1;
  --line-scale: 1;

  --bg-page: #f5f7f8;
  --bg-top: #eef3f3;

  --text-main: #0f172a;
  --text-muted: #64748b;

  --accent: #2f8485;

  --sentence-bg: rgba(47,132,133,.14);
  --sentence-border: rgba(47,132,133,.35);
  --word-bg: #fde68a;
  --word-border: #facc15;

  --radius-md: 16px;

  --max-width: 105ch;

  --popup-scale: 1;
}

/* ============================================================
   BASE
   ============================================================ */

html {
  font-size: 18px; /* større base */
}

body {
  margin: 0;
  background: var(--bg-page);
  color: var(--text-main);
  font-family: Georgia, "Times New Roman", serif;
}

/* ============================================================
   HEADER
   ============================================================ */

header {
  background: var(--bg-top);
  padding: 70px 20px 50px;
  margin-bottom: 50px;
  text-align: center;
}

header img {
  display: block;
  margin: 0 auto;
  max-height: 64px; /* større logo */
}

/* ============================================================
   NAVIGATION
   ============================================================ */

.reader-nav {
  max-width: var(--max-width);
  margin: 20px auto 0;
  text-align: center;
}

.reader-nav a {
  display: inline-block;
  padding: 10px 22px;
  border-radius: 999px;
  background: #e6eeee;
  color: #0f172a;
  text-decoration: none;
  font-weight: 500;
  transition: 0.2s ease;
}

.reader-nav a:hover {
  background: #d6e4e4;
}

/* ============================================================
   LAYOUT
   ============================================================ */

.book-container,
.book-container section {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 0 30px;
}

/* ============================================================
   TOOLS (A− A A+ + line height)
   ============================================================ */

.reader-tools {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin: 25px 0 40px;
  flex-wrap: wrap;
}

.reader-tools button {
  font-size: 1.05rem;
  padding: 8px 18px;
  border-radius: 10px;
  border: none;
  background: #e6eeee;
  cursor: pointer;
  transition: 0.2s ease;
}

.reader-tools button:hover {
  background: #d6e4e4;
}

/* ============================================================
   TEXT
   ============================================================ */

.reader {
  line-height: calc(1.8 * var(--line-scale));
}

.reader p {
  font-size: calc(1.5rem * var(--font-scale));
  margin-bottom: 1.9em;
}

.reader h2 {
  font-size: calc(2.4rem * var(--font-scale));
  margin-bottom: 1.5rem;
}

/* ============================================================
   SENTENCE / WORD
   ============================================================ */

.sentence,
.word {
  cursor: pointer;
  user-select: none;
}

.sentence.active {
  background: var(--sentence-bg);
  outline: 2px solid var(--sentence-border);
  border-radius: 6px;
}

.word.active {
  background: var(--word-bg);
  outline: 2px solid var(--word-border);
  border-radius: 4px;
}

/* ============================================================
   POPOVER
   ============================================================ */

.word-popover {
  position: absolute;
  z-index: 99999;
  max-width: 640px;
  background: #ffffff;
  border-radius: var(--radius-md);
  box-shadow: 0 28px 60px rgba(0,0,0,.2);
  pointer-events: auto;
  transform: scale(var(--popup-scale));
  transform-origin: top left;
}

.word-popover.hidden {
  display: none;
}

.lex-popup {
  padding: 30px 36px;
  font-family: system-ui, -apple-system, sans-serif;
}

.lex-term {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 24px;
}

.lex-heading {
  font-size: 0.95rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.lex-section {
  margin-bottom: 24px;
}

.lex-text {
  font-size: 1.2rem;
  line-height: 1.6;
}

/* ============================================================
   TABLE
   ============================================================ */

.lex-table {
  width: 100%;
  border-collapse: collapse;
}

.lex-table th,
.lex-table td {
  padding: 10px 0;
  text-align: left;
  border-bottom: 1px solid #e2e8f0;
}

.lex-table th {
  width: 50%;
  font-weight: 600;
  color: #334155;
}

.lex-table tr:last-child th,
.lex-table tr:last-child td {
  border-bottom: none;
}
